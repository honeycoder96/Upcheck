{
  "name": "@uptimemonitor/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "seed": "ts-node -r dotenv/config src/scripts/seed.ts",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "email:dev": "email dev --dir src/emails --port 3001"
  },
  "dependencies": {
    "@react-email/components": "^1.0.9",
    "@uptimemonitor/shared": "*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.4.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/winston": "^2.4.4",
    "react-email": "^5.2.9",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  }
}
